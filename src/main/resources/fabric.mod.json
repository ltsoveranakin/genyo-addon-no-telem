{
  "schemaVersion": 1,
  "id": "genyo",
  "version": "${version}",
  "name": "Genyo",
  "description": "Utility Meteor addon powered by special people's special minds.",
  "authors": [
    "wuritz",
    "Barnika18"
  ],
  "contact": {
    "homepage": "https://genyo.dev",
    "repo": "https://github.com/wuritz/genyo-addon"
  },
  "icon": "assets/genyo/icon.png",
  "accessWidener": "genyo.accesswidener",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.genyo.core.sound.SoundLoader"
    ],
    "meteor": [
      "com.genyo.Genyo"
    ]
  },
  "mixins": [
    "genyo.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "0,242,255",
    "github:sha": "${gh_hash}"
  },
  "depends": {
    "java": ">=21",
    "minecraft": ["${mc_version}"],
    "meteor-client": "*"
  }
}
